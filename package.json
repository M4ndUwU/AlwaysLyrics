{
  "name": "alwayslyrics",
  "version": "0.1.0",
  "private": true,
  "description": "YouTube Music 전용 데스크톱 가사 표시 — 동기 가사 검색은 MusixMatch만 사용 (AlwaysLyrics)",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "start:debug": "cross-env ALWAYSLYRICS_DEBUG=1 electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "fetch-cookie": "^3.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.alwayslyrics.app",
    "productName": "AlwaysLyrics",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
